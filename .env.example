# =============================================================
# .env.example — Arctic Nord Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.
#
#   cp .env.example .env
# =============================================================

# ── Flask ─────────────────────────────────────────────────────
# Random secret used to sign session cookies.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-random-value

# Set to "production" on live servers (enables secure cookies, disables debug)
FLASK_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────
# Full connection string for your PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#
# Local dev (PostgreSQL installed locally):
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/arctic_nord
#
# Docker Compose (if you add a postgres service):
#   DATABASE_URL=postgresql://postgres:password@db:5432/arctic_nord
#
# Hosted (Railway, Render, Supabase, etc.) — copy the connection string from
# the provider's dashboard and paste it here.
#
# SQLite fallback (no PostgreSQL needed, good for quick local dev):
#   DATABASE_URL=sqlite:///arctic_nord.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/arctic_nord

# ── Encryption (OAuth tokens) ─────────────────────────────────
# Fernet symmetric encryption key for storing OAuth tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this secret — losing it means encrypted tokens cannot be decrypted.
FERNET_KEY=generate-a-real-fernet-key-here

# ── OAuth providers (add when wiring OAuth login) ─────────────
# Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Discord
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# ── Rate limiter (optional — swap memory:// for Redis in prod) ─
# REDIS_URL=redis://localhost:6379/0
